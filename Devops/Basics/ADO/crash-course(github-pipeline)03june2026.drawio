  <diagram id="Ua7xsA29Ksl3q_nLe4Sg" name="ADO-interview">
    <mxGraphModel dx="1186" dy="516" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="WfoHyHS77yum5kZMieVa-1" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;" value="&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;1. Azure Boards&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Azure Boards is used for project planning and work tracking.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It helps teams manage Epics, Features, User Stories, Tasks, Bugs, and Sprints.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It provides visibility into project progress and team workload.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;2. Azure Repos&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Azure Repos is a source code management service based on Git.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It stores application and infrastructure code securely.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It supports branching, pull requests, code reviews, and version control.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;3. Azure Pipelines&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Azure Pipelines is a CI/CD service used to automate build, test, and deployment processes.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It supports YAML-based and classic pipelines.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It can deploy applications and infrastructure across Azure, AWS, GCP, and on-premises environments.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;4. Azure Test Plans&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Azure Test Plans helps teams perform manual and exploratory testing.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It allows creation and execution of test cases and test suites.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It ensures application quality before production deployment.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;5. Azure Artifacts&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Azure Artifacts is a package management service.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It stores and shares packages such as NuGet, npm, Maven, and Python packages.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It enables teams to manage dependencies securely and efficiently.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;6. Branching Strategy&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;A branching strategy defines how developers collaborate on code changes.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Common branches include Main, Develop, Feature, Release, and Hotfix.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It helps maintain code quality and supports parallel development.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;7. Pull Request (PR)&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;A Pull Request is used to merge code from one branch to another.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It enables code reviews and approval workflows before merging.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;PRs help enforce coding standards and reduce production issues.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;8. Service Connections&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Service Connections allow Azure DevOps to securely connect with external services.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Common examples include Azure subscriptions, GitHub, AKS, and Docker Hub.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;They eliminate the need to store credentials directly in pipelines.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;9. Variable Groups&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Variable Groups store reusable variables and secrets centrally.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Multiple pipelines can use the same variables without duplication.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Sensitive values can be linked from Azure Key Vault.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;10. Agent Pools&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Agent Pools contain build and deployment agents that execute pipeline jobs.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Agents can be Microsoft-hosted or self-hosted.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;They provide the compute resources required to run CI/CD tasks.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;11. Libraries&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Libraries are used to manage shared variables, secure files, and secrets.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;They centralize configuration management across multiple pipelines.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;This improves consistency and security.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;12. YAML Pipelines&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;YAML Pipelines define CI/CD workflows as code.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Pipeline configurations are stored in the repository and version-controlled.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;They provide automation, reusability, and easier maintenance.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;13. Approvals &amp;amp; Gates&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Approvals ensure deployments are reviewed before moving to the next environment.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Commonly used between Dev, QA, UAT, and Production stages.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;They help maintain governance and reduce deployment risks.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;14. Build Pipeline (CI)&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;A Build Pipeline automatically compiles, validates, and tests code changes.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It runs whenever developers commit code to the repository.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It ensures that only verified code moves forward in the delivery process.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;15. Release/Deployment Pipeline (CD)&lt;/font&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;A Deployment Pipeline automatically releases applications or infrastructure to target environments.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It supports staged deployments with approvals and rollback mechanisms.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;It enables faster and more reliable software delivery.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;br&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="1920" width="560" x="-60" y="310" as="geometry" />
        </mxCell>
        <mxCell id="WfoHyHS77yum5kZMieVa-3" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;In Azure DevOps, we use Azure Repos for source code management, Azure Boards for project tracking, Azure Pipelines for CI/CD automation, Service Connections for secure integrations, Variable Groups and Libraries for configuration management, Agent Pools for pipeline execution, and Approvals for controlled deployments. This enables automated, secure, and scalable software delivery.&quot;&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="560" x="-60" y="200" as="geometry" />
        </mxCell>
        <mxCell id="dypVlL1Pm483OvyxCJ_v-1" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#fad9d5;strokeColor=#ae4132;" value="&lt;strong data-start=&quot;0&quot; data-end=&quot;22&quot; style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;ADO = Azure DevOps&lt;/font&gt;&lt;/strong&gt;" vertex="1">
          <mxGeometry height="40" width="270" x="90" y="160" as="geometry" />
        </mxCell>
        <mxCell id="sbBxt68LOojkCEYJRJkE-1" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#d0cee2;strokeColor=#56517e;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Feature&lt;/font&gt;&lt;/th&gt;&lt;th&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Classic Pipeline&lt;/font&gt;&lt;/th&gt;&lt;th&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;YAML Pipeline&lt;/font&gt;&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Configuration&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;GUI-based (drag &amp;amp; drop)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Code-based (YAML file)&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Storage&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Stored in Azure DevOps UI&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Stored in Git repository&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Version Control&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Limited&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Full version control&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Reusability&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Difficult&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Easy using templates&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Code Review&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Not possible&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Possible through Pull Requests&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automation&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Basic&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Advanced&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Maintenance&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Hard for large projects&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Easy and scalable&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Infrastructure as Code&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Not supported&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Fully supported&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Industry Usage&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Legacy projects&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Modern projects (recommended)&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="240" width="590" x="-80" y="2340" as="geometry" />
        </mxCell>
        <mxCell id="sbBxt68LOojkCEYJRJkE-2" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#f8cecc;gradientColor=#ea6b66;strokeColor=#b85450;" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Classic Pipeline vs YAML Pipeline&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="290" x="50" y="2300" as="geometry" />
        </mxCell>
        <mxCell id="GcgwjuaxLJl_t1mmgVIg-1" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#d80073;fontColor=#ffffff;strokeColor=#A50040;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Azure DevOps Agent&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="240" x="50" y="2610" as="geometry" />
        </mxCell>
        <mxCell id="GcgwjuaxLJl_t1mmgVIg-3" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&quot;An Azure DevOps Agent is a worker machine that runs build, test, and deployment tasks defined in a pipeline.&quot;&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="600" x="-80" y="2650" as="geometry" />
        </mxCell>
        <mxCell id="GcgwjuaxLJl_t1mmgVIg-5" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;h1 data-section-id=&quot;18ix2ry&quot; data-start=&quot;514&quot; data-end=&quot;531&quot; style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Types of Agents&lt;/h1&gt;" vertex="1">
          <mxGeometry height="80" width="220" x="80" y="2730" as="geometry" />
        </mxCell>
        <mxCell id="GcgwjuaxLJl_t1mmgVIg-6" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="1. Microsoft-Hosted Agent" vertex="1">
          <mxGeometry height="40" width="170" x="130" y="2810" as="geometry" />
        </mxCell>
        <mxCell id="GcgwjuaxLJl_t1mmgVIg-7" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="2. Self-Hosted Agent" vertex="1">
          <mxGeometry height="40" width="140" x="130" y="2850" as="geometry" />
        </mxCell>
        <mxCell id="GcgwjuaxLJl_t1mmgVIg-8" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Feature&lt;/font&gt;&lt;/th&gt;&lt;th&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Microsoft Hosted&lt;/font&gt;&lt;/th&gt;&lt;th&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Self Hosted&lt;/font&gt;&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Managed By&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Microsoft&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Organization&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Setup Effort&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Very Low&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;High&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Maintenance&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Microsoft&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Organization&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Private Network Access&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;No&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Yes&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Custom Software&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Limited&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Full Control&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Cost&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Included minutes&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Infrastructure cost&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Security Control&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Medium&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;High&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
